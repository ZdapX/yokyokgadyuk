<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DevCORE | Polyglot IDE</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.23.4/ace.js"></script>
    <script src="https://cdn.jsdelivr.net/pyodide/v0.23.4/full/pyodide.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #ffffff;
            --sidebar-bg: #f6f8fa;
            --accent: #0969da;
            --border: #d0d7de;
            --text: #1f2328;
            --text-light: #636c76;
            --shadow: 0 8px 24px rgba(149,157,165,0.1);
        }

        * { box-sizing: border-box; transition: all 0.2s ease; }
        body { margin: 0; font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); height: 100vh; overflow: hidden; }

        /* DASHBOARD VIEW */
        #dashboard { padding: 40px 20px; max-width: 1000px; margin: 0 auto; height: 100vh; overflow-y: auto; display: block; }
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; border-bottom: 1px solid var(--border); padding-bottom: 20px; }
        .project-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
        .project-card { border: 1px solid var(--border); border-radius: 12px; padding: 24px; cursor: pointer; background: white; position: relative; }
        .project-card:hover { border-color: var(--accent); box-shadow: var(--shadow); transform: translateY(-2px); }
        .delete-proj-btn { position: absolute; top: 15px; right: 15px; color: #cf222e; background: none; border: none; cursor: pointer; font-size: 1.2rem; }

        /* EDITOR VIEW */
        #editor-view { display: none; height: 100vh; flex-direction: column; background: #fff; }
        .navbar { height: 60px; border-bottom: 1px solid var(--border); display: flex; align-items: center; padding: 0 15px; justify-content: space-between; background: #fff; z-index: 1000; }
        .workspace { display: flex; flex: 1; position: relative; overflow: hidden; }

        .sidebar { width: 280px; background: var(--sidebar-bg); border-right: 1px solid var(--border); display: flex; flex-direction: column; z-index: 999; }
        @media (max-width: 768px) {
            .sidebar { position: absolute; left: -280px; top: 0; bottom: 0; }
            .sidebar.active { left: 0; }
            .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.3); z-index: 998; }
            .overlay.active { display: block; }
        }

        .sidebar-content { padding: 20px; flex: 1; overflow-y: auto; }
        .file-item { padding: 10px 12px; border-radius: 8px; cursor: pointer; margin-bottom: 6px; display: flex; justify-content: space-between; font-size: 14px; align-items: center; }
        .file-item:hover { background: #fff; border: 1px solid var(--border); }
        .file-item.active { background: #fff; border: 1px solid var(--accent); color: var(--accent); font-weight: 600; }

        .editor-container { flex: 1; display: flex; flex-direction: column; min-width: 0; }
        #ace-editor { flex: 1; font-family: 'Fira Code', monospace; font-size: 14px; }

        .console { height: 40px; background: #0d1117; color: #e6edf3; transition: 0.3s; display: flex; flex-direction: column; }
        .console.expanded { height: 250px; }
        .console-header { padding: 10px 20px; background: #161b22; cursor: pointer; font-size: 12px; display: flex; justify-content: space-between; border-top: 1px solid #30363d; }
        .console-body { flex: 1; overflow-y: auto; padding: 15px; font-family: 'Fira Code', monospace; font-size: 13px; }

        .btn { padding: 8px 16px; border-radius: 6px; border: 1px solid var(--border); cursor: pointer; font-weight: 600; font-size: 14px; }
        .btn-primary { background: var(--accent); color: white; border: none; }
        .btn-run { background: #2da44e; color: white; border: none; }
        input, select { padding: 10px; border: 1px solid var(--border); border-radius: 8px; margin-bottom: 12px; width: 100%; }
        .menu-toggle { display: none; background: none; border: none; font-size: 24px; cursor: pointer; }
        @media (max-width: 768px) { .menu-toggle { display: block; } }

        #customLangInput { display: none; } /* Hidden by default */
    </style>
</head>
<body>

<div class="overlay" id="overlay" onclick="toggleSidebar()"></div>

<!-- VIEW 1: DASHBOARD -->
<div id="dashboard">
    <div class="header">
        <h1>📁 Repositories</h1>
        <button class="btn btn-primary" onclick="promptNewProject()">+ New Project</button>
    </div>
    <div class="project-grid" id="projectGrid"></div>
</div>

<!-- VIEW 2: EDITOR -->
<div id="editor-view">
    <nav class="navbar">
        <div style="display: flex; align-items: center;">
            <button class="menu-toggle" onclick="toggleSidebar()">☰</button>
            <button class="btn" style="border:none; background:none;" onclick="backToDashboard()">← Back</button>
            <span id="activeProjName" style="font-weight: 600; margin-left: 10px;">Project</span>
        </div>
        <div style="display: flex; gap: 8px;">
            <button class="btn btn-run" onclick="runCode()">▶ RUN</button>
            <button class="btn" onclick="saveCurrentFile()">Save</button>
        </div>
    </nav>

    <div class="workspace">
        <div class="sidebar" id="sidebar">
            <div class="sidebar-content">
                <p style="font-size: 11px; font-weight: 700; color: var(--text-light); text-transform: uppercase;">Add File</p>
                <input type="text" id="newFileName" placeholder="filename.js">
                
                <select id="newFileLang" onchange="checkLang(this.value)">
                    <option value="javascript">JavaScript</option>
                    <option value="python">Python</option>
                    <option value="html">HTML</option>
                    <option value="css">CSS</option>
                    <option value="other">-- Custom / Other --</option>
                </select>
                
                <!-- Input Manual Bahasa -->
                <input type="text" id="customLangInput" placeholder="Enter language (e.g. php, sh, c_cpp)">
                
                <button class="btn btn-primary" style="width: 100%;" onclick="createNewFile()">Create File</button>
                <hr style="border: 0; border-top: 1px solid var(--border); margin: 20px 0;">
                <div id="fileList"></div>
            </div>
        </div>

        <div class="editor-container">
            <div id="ace-editor"></div>
            <div class="console" id="console">
                <div class="console-header" onclick="toggleConsole()">
                    <span>TERMINAL</span>
                    <span id="c-arrow">▲</span>
                </div>
                <div class="console-body" id="consoleBody"></div>
            </div>
        </div>
    </div>
</div>

<script>
    let editor = ace.edit("ace-editor");
    editor.setTheme("ace/theme/chrome");
    editor.setOptions({ enableBasicAutocompletion: true, enableLiveAutocompletion: true, showPrintMargin: false });

    let db = JSON.parse(localStorage.getItem('devcore_v6_db')) || { projects: {} };
    let currentProj = null, currentFile = null, pyodide = null;

    // --- DYNAMIC ENGINE ---
    async function initPy() {
        try {
            pyodide = await loadPyodide();
            pyodide.setStdout({ batched: (text) => log("Output", text) });
            log("System", "Python Online.");
        } catch(e) { log("Error", "Python Init Failed."); }
    }
    initPy();

    function checkLang(val) {
        const customInput = document.getElementById('customLangInput');
        customInput.style.display = (val === 'other') ? 'block' : 'none';
    }

    function toggleSidebar() {
        document.getElementById('sidebar').classList.toggle('active');
        document.getElementById('overlay').classList.toggle('active');
    }

    function toggleConsole(force = false) {
        const c = document.getElementById('console');
        if (force) c.classList.add('expanded'); else c.classList.toggle('expanded');
        document.getElementById('c-arrow').innerText = c.classList.contains('expanded') ? '▼' : '▲';
    }

    function backToDashboard() {
        document.getElementById('dashboard').style.display = 'block';
        document.getElementById('editor-view').style.display = 'none';
        renderDashboard();
    }

    function openProject(pName) {
        currentProj = pName;
        document.getElementById('dashboard').style.display = 'none';
        document.getElementById('editor-view').style.display = 'flex';
        document.getElementById('activeProjName').innerText = pName;
        renderFileList();
    }

    // --- DB OPS ---
    function saveDB() { localStorage.setItem('devcore_v6_db', JSON.stringify(db)); }

    function promptNewProject() {
        const name = prompt("Project Name:");
        if (name && !db.projects[name]) { db.projects[name] = { files: {} }; saveDB(); renderDashboard(); }
    }

    function createNewFile() {
        const name = document.getElementById('newFileName').value.trim();
        let lang = document.getElementById('newFileLang').value;
        const customLang = document.getElementById('customLangInput').value.trim().toLowerCase();

        if (!name) return alert("Enter filename!");
        if (lang === 'other') {
            if (!customLang) return alert("Enter custom language name!");
            lang = customLang;
        }

        db.projects[currentProj].files[name] = { content: "", lang: lang };
        document.getElementById('newFileName').value = "";
        document.getElementById('customLangInput').value = "";
        saveDB();
        renderFileList();
    }

    function renderDashboard() {
        const grid = document.getElementById('projectGrid'); grid.innerHTML = "";
        Object.keys(db.projects).forEach(p => {
            const card = document.createElement('div');
            card.className = 'project-card';
            card.innerHTML = `<button class="delete-proj-btn" onclick="deleteProj(event, '${p}')">×</button><h3>📁 ${p}</h3><p>${Object.keys(db.projects[p].files).length} files</p>`;
            card.onclick = () => openProject(p);
            grid.appendChild(card);
        });
    }

    function deleteProj(e, p) {
        e.stopPropagation(); if(confirm(`Delete ${p}?`)) { delete db.projects[p]; saveDB(); renderDashboard(); }
    }

    function renderFileList() {
        const list = document.getElementById('fileList'); list.innerHTML = "";
        const files = db.projects[currentProj].files;
        Object.keys(files).forEach(f => {
            const item = document.createElement('div');
            item.className = `file-item ${currentFile === f ? 'active' : ''}`;
            item.innerHTML = `<span>📄 ${f}</span><span onclick="deleteFile(event, '${f}')" style="color:red">×</span>`;
            item.onclick = () => loadFile(f);
            list.appendChild(item);
        });
    }

    function loadFile(f) {
        currentFile = f;
        const data = db.projects[currentProj].files[f];
        editor.setValue(data.content, -1);
        
        // Dynamic Mode Loading
        let mode = data.lang;
        if(mode === 'python') mode = 'python';
        if(mode === 'javascript' || mode === 'js') mode = 'javascript';
        editor.session.setMode("ace/mode/" + mode);
        
        renderFileList();
        if(window.innerWidth <= 768) toggleSidebar();
    }

    function saveCurrentFile() {
        if(!currentFile) return;
        db.projects[currentProj].files[currentFile].content = editor.getValue();
        saveDB(); log("System", "Saved " + currentFile);
    }

    function deleteFile(e, f) {
        e.stopPropagation(); if(confirm(`Delete ${f}?`)) { delete db.projects[currentProj].files[f]; saveDB(); renderFileList(); }
    }

    function log(type, msg) {
        const b = document.getElementById('consoleBody');
        b.innerHTML += `<div><span style="color:#8b949e">[${type}]</span> ${msg}</div>`;
        b.scrollTop = b.scrollHeight;
    }

    // --- RUN ENGINE ---
    async function runCode() {
        if(!currentFile) return;
        const code = editor.getValue();
        const lang = db.projects[currentProj].files[currentFile].lang;
        document.getElementById('consoleBody').innerHTML = ""; 
        toggleConsole(true);
        log("Exec", "Running " + currentFile);

        if(lang === 'html') {
            const win = window.open(); win.document.write(code); win.document.close();
        } else if(lang === 'javascript' || lang === 'js') {
            try { console.log = (m) => log("Output", m); eval(code); } catch(e) { log("Error", e.message); }
        } else if(lang === 'python') {
            if(!pyodide) return log("Error", "Python loading...");
            try {
                await pyodide.runPythonAsync(`import builtins\nfrom js import window\ndef custom_input(p=""): return window.prompt(p)\nbuiltins.input = custom_input`);
                let res = await pyodide.runPythonAsync(code);
                if(res !== undefined) log("Return", res);
            } catch(e) { log("Error", e.message); }
        } else {
            log("System", `Language '${lang}' is not supported for direct execution in browser. Mode highlighting only.`);
        }
    }

    renderDashboard();
</script>
</body>
</html>
