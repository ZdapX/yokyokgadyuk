<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DevCORE | Project Hub</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.23.4/ace.js"></script>
    <script src="https://cdn.jsdelivr.net/pyodide/v0.23.4/full/pyodide.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #ffffff;
            --sidebar-bg: #f6f8fa;
            --accent: #0969da;
            --border: #d0d7de;
            --text: #1f2328;
            --text-light: #636c76;
            --shadow: 0 8px 24px rgba(149,157,165,0.2);
        }

        * { box-sizing: border-box; transition: all 0.2s ease; }
        body { margin: 0; font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); height: 100vh; overflow: hidden; }

        /* DASHBOARD VIEW */
        #dashboard {
            padding: 40px 20px;
            max-width: 1000px;
            margin: 0 auto;
            display: block; /* Default */
            height: 100vh;
            overflow-y: auto;
        }

        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        .project-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
        .project-card { 
            border: 1px solid var(--border); 
            border-radius: 8px; 
            padding: 20px; 
            cursor: pointer;
            background: white;
        }
        .project-card:hover { border-color: var(--accent); box-shadow: var(--shadow); }

        /* EDITOR VIEW */
        #editor-view { display: none; height: 100vh; flex-direction: column; }

        .navbar {
            height: 60px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 15px;
            justify-content: space-between;
            background: #fff;
            z-index: 101;
        }

        .workspace { display: flex; flex: 1; position: relative; overflow: hidden; }

        /* SIDEBAR STABLE */
        .sidebar {
            width: 280px;
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            z-index: 100;
        }

        @media (max-width: 768px) {
            .sidebar {
                position: absolute;
                left: -280px;
                top: 0; bottom: 0;
                transition: left 0.3s ease;
            }
            .sidebar.active { left: 0; }
            .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.3); z-index: 99; }
            .overlay.active { display: block; }
        }

        .sidebar-content { padding: 15px; flex: 1; }
        .file-item {
            padding: 8px 12px;
            border-radius: 6px;
            cursor: pointer;
            margin-bottom: 4px;
            display: flex;
            justify-content: space-between;
            font-size: 14px;
        }
        .file-item:hover { background: #ebf0f4; }
        .file-item.active { background: #0969da15; color: var(--accent); font-weight: 600; }

        /* EDITOR & CONSOLE */
        .editor-container { flex: 1; display: flex; flex-direction: column; min-width: 0; }
        #ace-editor { flex: 1; font-family: 'Fira Code', monospace; }

        .console {
            height: 40px;
            background: #0d1117;
            color: #e6edf3;
            transition: height 0.3s;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }
        .console.expanded { height: 200px; }
        .console-header { 
            padding: 10px 20px; 
            background: #161b22; 
            cursor: pointer; 
            font-size: 12px; 
            display: flex; 
            justify-content: space-between; 
        }
        .console-body { flex: 1; overflow-y: auto; padding: 10px; font-family: 'Fira Code', monospace; font-size: 13px; }

        /* UTILS */
        .btn { padding: 8px 16px; border-radius: 6px; border: 1px solid var(--border); cursor: pointer; font-weight: 600; font-size: 14px; }
        .btn-primary { background: var(--accent); color: white; border: none; }
        .btn-run { background: #2da44e; color: white; border: none; }
        input { padding: 8px; border: 1px solid var(--border); border-radius: 6px; margin-bottom: 10px; width: 100%; }
        .menu-toggle { display: none; background: none; border: none; font-size: 20px; cursor: pointer; }
        @media (max-width: 768px) { .menu-toggle { display: block; } }
    </style>
</head>
<body>

<div class="overlay" id="overlay" onclick="closeSidebar()"></div>

<!-- VIEW 1: DASHBOARD -->
<div id="dashboard">
    <div class="header">
        <h1>My Projects</h1>
        <button class="btn btn-primary" onclick="promptNewProject()">+ New Project</button>
    </div>
    <div class="project-grid" id="projectGrid">
        <!-- Rendered by JS -->
    </div>
</div>

<!-- VIEW 2: EDITOR -->
<div id="editor-view">
    <nav class="navbar">
        <div style="display: flex; align-items: center; gap: 10px;">
            <button class="menu-toggle" onclick="toggleSidebar()">☰</button>
            <button class="btn" onclick="backToDashboard()">← Back</button>
            <b id="activeProjName">Project</b>
        </div>
        <div style="display: flex; gap: 10px;">
            <button class="btn btn-run" onclick="runCode()">RUN</button>
            <button class="btn" onclick="saveCurrentFile()">Save</button>
        </div>
    </nav>

    <div class="workspace">
        <div class="sidebar" id="sidebar">
            <div class="sidebar-content">
                <input type="text" id="newFileName" placeholder="filename.js">
                <select id="newFileLang" style="width: 100%; margin-bottom: 10px; padding: 5px;">
                    <option value="javascript">JavaScript</option>
                    <option value="html">HTML</option>
                    <option value="python">Python</option>
                </select>
                <button class="btn btn-primary" style="width: 100%;" onclick="createNewFile()">Add File</button>
                <hr style="border: 0; border-top: 1px solid var(--border); margin: 20px 0;">
                <div id="fileList"></div>
            </div>
        </div>

        <div class="editor-container">
            <div id="ace-editor"></div>
            <div class="console" id="console">
                <div class="console-header" onclick="toggleConsole()">
                    <span>TERMINAL</span>
                    <span id="c-arrow">▲</span>
                </div>
                <div class="console-body" id="consoleBody"></div>
            </div>
        </div>
    </div>
</div>

<script>
    let editor = ace.edit("ace-editor");
    editor.setTheme("ace/theme/chrome");
    editor.session.setMode("ace/mode/javascript");
    editor.setOptions({ fontSize: "14px", showPrintMargin: false });

    let db = JSON.parse(localStorage.getItem('devcore_v4_db')) || { projects: {} };
    let currentProj = null;
    let currentFile = null;
    let pyodide = null;

    // Load Python Engine
    async function initPy() {
        try {
            pyodide = await loadPyodide();
            log("System", "Python VM Stable.");
        } catch(e) { log("Error", "Python failed."); }
    }
    initPy();

    // VIEW LOGIC
    function backToDashboard() {
        document.getElementById('dashboard').style.display = 'block';
        document.getElementById('editor-view').style.display = 'none';
        renderDashboard();
    }

    function openProject(pName) {
        currentProj = pName;
        document.getElementById('dashboard').style.display = 'none';
        document.getElementById('editor-view').style.display = 'flex';
        document.getElementById('activeProjName').innerText = pName;
        renderFileList();
    }

    // UI LOGIC
    function toggleSidebar() {
        document.getElementById('sidebar').classList.toggle('active');
        document.getElementById('overlay').classList.toggle('active');
    }
    function closeSidebar() {
        document.getElementById('sidebar').classList.remove('active');
        document.getElementById('overlay').classList.remove('active');
    }
    function toggleConsole() {
        const c = document.getElementById('console');
        c.classList.toggle('expanded');
        document.getElementById('c-arrow').innerText = c.classList.contains('expanded') ? '▼' : '▲';
    }

    // DB LOGIC
    function saveDB() { localStorage.setItem('devcore_v4_db', JSON.stringify(db)); }

    function promptNewProject() {
        const name = prompt("Project Name:");
        if (name && !db.projects[name]) {
            db.projects[name] = { files: {} };
            saveDB();
            renderDashboard();
        }
    }

    function createNewFile() {
        const name = document.getElementById('newFileName').value.trim();
        const lang = document.getElementById('newFileLang').value;
        if (!name) return;
        db.projects[currentProj].files[name] = { content: "", lang: lang };
        document.getElementById('newFileName').value = "";
        saveDB();
        renderFileList();
    }

    function renderDashboard() {
        const grid = document.getElementById('projectGrid');
        grid.innerHTML = "";
        Object.keys(db.projects).forEach(p => {
            const card = document.createElement('div');
            card.className = 'project-card';
            card.innerHTML = `<h3>📁 ${p}</h3><p style="color:var(--text-light)">${Object.keys(db.projects[p].files).length} Files</p>
            <button class="btn" style="color:red; border:none; padding:0;" onclick="deleteProj(event, '${p}')">Delete Project</button>`;
            card.onclick = () => openProject(p);
            grid.appendChild(card);
        });
    }

    function deleteProj(e, p) {
        e.stopPropagation();
        if(confirm("Delete Project?")) { delete db.projects[p]; saveDB(); renderDashboard(); }
    }

    function renderFileList() {
        const list = document.getElementById('fileList');
        list.innerHTML = "";
        const files = db.projects[currentProj].files;
        Object.keys(files).forEach(f => {
            const item = document.createElement('div');
            item.className = `file-item ${currentFile === f ? 'active' : ''}`;
            item.innerHTML = `<span>📄 ${f}</span><span onclick="deleteFile(event, '${f}')">×</span>`;
            item.onclick = () => loadFile(f);
            list.appendChild(item);
        });
    }

    function loadFile(f) {
        currentFile = f;
        const data = db.projects[currentProj].files[f];
        editor.setValue(data.content, -1);
        editor.session.setMode("ace/mode/" + data.lang);
        renderFileList();
        if(window.innerWidth <= 768) closeSidebar();
    }

    function saveCurrentFile() {
        if(!currentFile) return;
        db.projects[currentProj].files[currentFile].content = editor.getValue();
        saveDB();
        log("System", `Saved ${currentFile}`);
    }

    function deleteFile(e, f) {
        e.stopPropagation();
        if(confirm("Delete file?")) { delete db.projects[currentProj].files[f]; saveDB(); renderFileList(); }
    }

    function log(type, msg) {
        const b = document.getElementById('consoleBody');
        b.innerHTML += `<div><span style="color:#8b949e">[${type}]</span> ${msg}</div>`;
        b.scrollTop = b.scrollHeight;
        if (!document.getElementById('console').classList.contains('expanded')) toggleConsole();
    }

    // RUN EXECUTION
    async function runCode() {
        if(!currentFile) return;
        const code = editor.getValue();
        const lang = db.projects[currentProj].files[currentFile].lang;
        
        document.getElementById('consoleBody').innerHTML = ""; // Clear console
        log("Exec", `Running ${currentFile}...`);

        if(lang === 'html') {
            const win = window.open();
            win.document.write(code);
            win.document.close();
        } else if(lang === 'javascript') {
            try {
                // Hijack console.log
                const oldLog = console.log;
                console.log = (m) => log("Output", m);
                eval(code);
                setTimeout(() => { console.log = oldLog; }, 100);
            } catch(e) { log("Error", e.message); }
        } else if(lang === 'python') {
            if(!pyodide) return log("System", "Wait for Python...");
            try {
                let out = await pyodide.runPythonAsync(code);
                log("Output", out || "Success (No return)");
            } catch(e) { log("Error", e.message); }
        }
    }

    renderDashboard();
</script>
</body>
</html>
