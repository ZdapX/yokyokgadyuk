<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DevCORE | Terminal</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.23.4/ace.js"></script>
    <script src="https://cdn.jsdelivr.net/pyodide/v0.23.4/full/pyodide.js"></script>
    <style>
        body { margin: 0; background: #0a0a0a; color: #00ff41; font-family: 'Courier New', Courier, monospace; overflow: hidden; }
        .container { display: flex; height: 100vh; }
        .sidebar { width: 250px; background: #111; border-right: 1px solid #333; display: flex; flex-direction: column; }
        .main { flex: 1; display: flex; flex-direction: column; }
        #editor { flex: 1; font-size: 14px; }
        .toolbar { padding: 10px; background: #1a1a1a; display: flex; gap: 10px; border-bottom: 1px solid #333; }
        .file-list { flex: 1; overflow-y: auto; padding: 10px; }
        .file-item { padding: 5px; cursor: pointer; border-bottom: 1px solid #222; display: flex; justify-content: space-between; }
        .file-item:hover { background: #222; }
        button { background: #00ff41; color: black; border: none; padding: 5px 10px; cursor: pointer; font-weight: bold; }
        button.delete { background: #ff4141; margin-left: 5px; }
        #output { height: 200px; background: #000; border-top: 2px solid #333; overflow: auto; padding: 10px; font-size: 12px; color: #ddd; }
        input, select { background: #222; color: #00ff41; border: 1px solid #444; padding: 5px; }
    </style>
</head>
<body>

<div class="container">
    <div class="sidebar">
        <div class="toolbar" style="flex-direction: column;">
            <input type="text" id="filename" placeholder="filename.js">
            <select id="language">
                <option value="javascript">JavaScript</option>
                <option value="html">HTML</option>
                <option value="python">Python</option>
                <option value="css">CSS</option>
            </select>
            <button onclick="createFile()">NEW FILE</button>
        </div>
        <div class="file-list" id="fileList"></div>
    </div>
    <div class="main">
        <div class="toolbar">
            <span id="currentFile">No File Open</span>
            <button onclick="saveFile()">SAVE</button>
            <button onclick="runCode()" style="background: #008f11; color: white;">RUN</button>
        </div>
        <div id="editor"></div>
        <div id="output">
            <div id="console-out">SYSTEM READY... Waiting for input.</div>
        </div>
    </div>
</div>

<script>
    let editor = ace.edit("editor");
    editor.setTheme("ace/theme/monokai");
    editor.session.setMode("ace/mode/javascript");

    let files = JSON.parse(localStorage.getItem('devcore_files')) || {};
    let currentOpenFile = null;
    let pyodide = null;

    async function initPython() {
        log("Loading Python VM...");
        pyodide = await loadPyodide();
        log("Python Ready.");
    }
    initPython();

    function log(msg) {
        const out = document.getElementById('console-out');
        out.innerHTML += `<div>> ${msg}</div>`;
        document.getElementById('output').scrollTop = document.getElementById('output').scrollHeight;
    }

    function updateFileList() {
        const list = document.getElementById('fileList');
        list.innerHTML = '';
        for (let name in files) {
            let div = document.createElement('div');
            div.className = 'file-item';
            div.innerHTML = `<span onclick="openFile('${name}')">${name}</span> 
                             <button class="delete" onclick="deleteFile('${name}')">X</button>`;
            list.appendChild(div);
        }
        localStorage.setItem('devcore_files', JSON.stringify(files));
    }

    function createFile() {
        const name = document.getElementById('filename').value;
        const lang = document.getElementById('language').value;
        if (!name) return alert("Kasih nama filenya!");
        files[name] = { content: "", lang: lang };
        updateFileList();
        openFile(name);
    }

    function openFile(name) {
        currentOpenFile = name;
        document.getElementById('currentFile').innerText = name;
        editor.setValue(files[name].content);
        editor.session.setMode("ace/mode/" + files[name].lang);
    }

    function saveFile() {
        if (!currentOpenFile) return;
        files[currentOpenFile].content = editor.getValue();
        updateFileList();
        log(`File ${currentOpenFile} saved to local storage.`);
    }

    function deleteFile(name) {
        if (confirm(`Hapus ${name}?`)) {
            delete files[name];
            if (currentOpenFile === name) {
                currentOpenFile = null;
                editor.setValue("");
                document.getElementById('currentFile').innerText = "No File Open";
            }
            updateFileList();
        }
    }

    async function runCode() {
        if (!currentOpenFile) return;
        const code = editor.getValue();
        const lang = files[currentOpenFile].lang;
        document.getElementById('console-out').innerHTML = ""; // Clear console

        if (lang === 'html') {
            const win = window.open();
            win.document.write(code);
            win.document.close();
        } else if (lang === 'javascript') {
            try {
                const result = eval(code);
                log(result);
            } catch (e) {
                log("Error: " + e.message);
            }
        } else if (lang === 'python') {
            if (!pyodide) return log("Python still loading...");
            try {
                let output = await pyodide.runPythonAsync(code);
                log(output);
            } catch (e) {
                log("Python Error: " + e.message);
            }
        }
    }

    updateFileList();
</script>
</body>
</html>
