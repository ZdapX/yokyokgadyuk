<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DevCORE | Premium Editor</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.23.4/ace.js"></script>
    <script src="https://cdn.jsdelivr.net/pyodide/v0.23.4/full/pyodide.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-main: #f8f9fa;
            --bg-sidebar: #ffffff;
            --accent: #2563eb;
            --text-dark: #1e293b;
            --text-light: #64748b;
            --border: #e2e8f0;
            --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }

        body { 
            margin: 0; 
            background: var(--bg-main); 
            color: var(--text-dark); 
            font-family: 'Inter', sans-serif; 
            overflow: hidden; 
        }

        .container { display: flex; height: 100vh; }

        /* Sidebar - Navigation */
        .sidebar { 
            width: 280px; 
            background: var(--bg-sidebar); 
            border-right: 1px solid var(--border); 
            display: flex; 
            flex-direction: column; 
            box-shadow: 2px 0 10px rgba(0,0,0,0.02);
        }

        .brand {
            padding: 20px;
            font-weight: 600;
            font-size: 1.2rem;
            color: var(--accent);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .file-controls { padding: 20px; border-bottom: 1px solid var(--border); }
        .file-controls input, .file-controls select {
            width: 100%;
            padding: 8px;
            margin-bottom: 10px;
            border: 1px solid var(--border);
            border-radius: 6px;
            font-size: 0.9rem;
            box-sizing: border-box;
        }

        .btn-primary {
            width: 100%;
            background: var(--accent);
            color: white;
            border: none;
            padding: 10px;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .file-list { flex: 1; overflow-y: auto; padding: 10px; }
        .file-item {
            padding: 10px 15px;
            border-radius: 8px;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 5px;
            transition: all 0.2s;
            font-size: 0.9rem;
            color: var(--text-light);
        }
        .file-item:hover { background: #f1f5f9; color: var(--text-dark); }
        .file-item.active { background: #eff6ff; color: var(--accent); font-weight: 600; }

        /* Main Editor Area */
        .main { flex: 1; display: flex; flex-direction: column; background: white; }
        .header-bar {
            height: 60px;
            padding: 0 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid var(--border);
        }

        #editor { flex: 1; font-family: 'Fira Code', monospace; font-size: 14px; }

        .action-btns { display: flex; gap: 10px; }
        .btn-run { background: #10b981; color: white; border: none; padding: 8px 20px; border-radius: 6px; cursor: pointer; font-weight: 600; }
        .btn-save { background: #f1f5f9; color: var(--text-dark); border: 1px solid var(--border); padding: 8px 15px; border-radius: 6px; cursor: pointer; }

        /* Bottom Console */
        .console {
            height: 180px;
            background: #1e293b;
            color: #e2e8f0;
            padding: 15px;
            font-family: 'Fira Code', monospace;
            font-size: 0.85rem;
            overflow-y: auto;
            border-top: 4px solid var(--border);
        }

        .btn-delete { color: #ef4444; background: none; border: none; cursor: pointer; font-weight: bold; }
    </style>
</head>
<body>

<div class="container">
    <div class="sidebar">
        <div class="brand">
            <div style="width:12px; height:12px; background:var(--accent); border-radius:50%;"></div>
            DevCORE Studio
        </div>
        <div class="file-controls">
            <input type="text" id="filename" placeholder="new_file.js">
            <select id="language">
                <option value="javascript">JavaScript</option>
                <option value="html">HTML</option>
                <option value="python">Python</option>
                <option value="css">CSS</option>
            </select>
            <button class="btn-primary" onclick="createFile()">Create File</button>
        </div>
        <div class="file-list" id="fileList"></div>
    </div>

    <div class="main">
        <div class="header-bar">
            <div>
                <span style="color: var(--text-light); font-size: 0.8rem;">Current File:</span>
                <span id="currentFile" style="font-weight: 600; margin-left: 5px;">None Selected</span>
            </div>
            <div class="action-btns">
                <button class="btn-save" onclick="saveFile()">Save Changes</button>
                <button class="btn-run" onclick="runCode()">Run Program</button>
            </div>
        </div>
        <div id="editor"></div>
        <div class="console" id="console">
            <div style="color: #94a3b8;">// System initialized. Awaiting input...</div>
        </div>
    </div>
</div>

<script>
    let editor = ace.edit("editor");
    editor.setTheme("ace/theme/chrome"); // Light Theme for high-class feel
    editor.session.setMode("ace/mode/javascript");
    editor.setOptions({
        enableBasicAutocompletion: true,
        enableLiveAutocompletion: true,
        showPrintMargin: false,
        padding: { top: 10 }
    });

    let files = JSON.parse(localStorage.getItem('devcore_v2_files')) || {};
    let currentOpenFile = null;
    let pyodide = null;

    async function initPython() {
        log("System", "Loading Python Runtime...");
        try {
            pyodide = await loadPyodide();
            log("System", "Python Virtual Machine Ready.");
        } catch(e) { log("Error", "Failed to load Python."); }
    }
    initPython();

    function log(type, msg) {
        const consoleEl = document.getElementById('console');
        const time = new Date().toLocaleTimeString().split(' ')[0];
        consoleEl.innerHTML += `<div style="margin-bottom:4px"><span style="color:#64748b">[${time}]</span> <span style="color:${type==='Error'?'#f87171':'#34d399'}">${type}:</span> ${msg}</div>`;
        consoleEl.scrollTop = consoleEl.scrollHeight;
    }

    function updateFileList() {
        const list = document.getElementById('fileList');
        list.innerHTML = '';
        for (let name in files) {
            let div = document.createElement('div');
            div.className = `file-item ${currentOpenFile === name ? 'active' : ''}`;
            div.innerHTML = `
                <span onclick="openFile('${name}')" style="flex:1">📄 ${name}</span> 
                <button class="btn-delete" onclick="deleteFile('${name}')">×</button>
            `;
            list.appendChild(div);
        }
        localStorage.setItem('devcore_v2_files', JSON.stringify(files));
    }

    function createFile() {
        const name = document.getElementById('filename').value.trim();
        const lang = document.getElementById('language').value;
        if (!name) return alert("Enter a filename!");
        if (files[name]) return alert("File already exists!");
        
        files[name] = { content: "", lang: lang };
        document.getElementById('filename').value = "";
        updateFileList();
        openFile(name);
    }

    function openFile(name) {
        currentOpenFile = name;
        document.getElementById('currentFile').innerText = name;
        editor.setValue(files[name].content, -1);
        editor.session.setMode("ace/mode/" + files[name].lang);
        updateFileList();
    }

    function saveFile() {
        if (!currentOpenFile) return log("System", "No file selected to save.");
        files[currentOpenFile].content = editor.getValue();
        updateFileList();
        log("System", `File '${currentOpenFile}' secured to storage.`);
    }

    function deleteFile(name) {
        if (confirm(`Delete ${name} permanently?`)) {
            delete files[name];
            if (currentOpenFile === name) {
                currentOpenFile = null;
                editor.setValue("");
                document.getElementById('currentFile').innerText = "None Selected";
            }
            updateFileList();
        }
    }

    async function runCode() {
        if (!currentOpenFile) return;
        const code = editor.getValue();
        const lang = files[currentOpenFile].lang;
        
        log("Execute", `Running ${currentOpenFile}...`);

        if (lang === 'html') {
            const win = window.open();
            win.document.write(code);
            win.document.close();
        } else if (lang === 'javascript') {
            try {
                // Redirecting console.log to our internal console
                const oldLog = console.log;
                console.log = (m) => log("Output", m);
                eval(code);
                console.log = oldLog;
            } catch (e) {
                log("Error", e.message);
            }
        } else if (lang === 'python') {
            if (!pyodide) return log("System", "Python is still booting...");
            try {
                let output = await pyodide.runPythonAsync(code);
                log("Output", output || "Script executed (no return value)");
            } catch (e) {
                log("Error", e.message);
            }
        }
    }

    updateFileList();
</script>
</body>
</html>
